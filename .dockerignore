# ================================
# Git
# ================================
.git
.gitignore

# ================================
# Python cache files
# ================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ================================
# Virtual environments
# ================================
.venv/
venv/
env/
ENV/

# ================================
# Poetry
# ================================
# Keep pyproject.toml and poetry.lock, ignore local poetry cache
.cache/

# ================================
# Environment / Secrets
# ================================
.env
.env.*
*.env

# ================================
# IDE / Editor configs
# ================================
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ================================
# OS files
# ================================
.DS_Store
Thumbs.db
desktop.ini

# ================================
# Testing
# ================================
.pytest_cache/
.coverage
htmlcov/
*.xml
tests/

# ================================
# Scripts (seed scripts etc.)
# ================================
scripts/

# ================================
# Documentation
# ================================
README.md
docs/

# ================================
# Docker itself (avoid recursion)
# ================================
Dockerfile
.dockerignore
docker-compose*.yml
