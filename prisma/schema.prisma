datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

model User {
  id            Int           @id @default(autoincrement())
  fullname      String
  email         String        @unique
  password      String
  isAgreed      Boolean       @default(false)
  roles         Role[]        @default([USER])
  isVerified    Boolean       @default(false)
  accountStatus AccountStatus @default(PENDING)
  otp           String?
  displayname   String?
  bio           String?
  longitude     Float?
  latitude      Float?
  tokenVersion  Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  profile       UserProfile?
  products      Product[]
  orders        Order[]
  
  reviews_given    Review[] @relation("BuyerReviews")
  reviews_received Review[] @relation("SellerReviews")
  
  messages_sent     Message[] @relation("SentMessages")
  messages_received Message[] @relation("ReceivedMessages")

  @@map("users")
}

model UserProfile {
  id           Int     @id @default(autoincrement())
  profile_image String?
  raw_score    Float   @default(0)
  trust_score  Float   @default(0)
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

enum Role {
  USER
  SELLER
  SERVICE_PROVIDER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING
  DEACTIVE
  SUSPEND
  DELETE
}


model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id            Int              @id @default(autoincrement())
  title         String
  description   String
  images        String[]
  price         Float
  tax_fee       Float?           @default(0)
  delivery_fee  Float?           @default(0)
  total_fee     Float            @default(0)
  condition     ProductCondition
  status        ProductStatus    @default(ACTIVE)
  longitude     Float?
  latitude      Float?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  sellerId      Int
  seller        User             @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  categoryId    Int
  category      Category         @relation(fields: [categoryId], references: [id])
  orders        Order[]
  reviews       Review[]

  @@map("products")
}

model Order {
  id        Int             @id @default(autoincrement())
  status    OrderStatus     @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  tracking  OrderTracking[]
  review    Review?

  @@map("orders")
}

model OrderTracking {
  id        Int      @id @default(autoincrement())
  status    String
  createdAt DateTime @default(now())
  
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_trackings")
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  images    String[]
  createdAt DateTime @default(now())

  buyerId   Int
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id])

  sellerId  Int
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id])

  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderId   Int      @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Message {
  id          Int         @id @default(autoincrement())
  content     String
  type        MessageType @default(TEXT)
  fileUrl     String?
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  senderId    Int
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId  Int
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  replyToId   Int?
  replyTo     Message?    @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[]   @relation("MessageReplies")

  @@map("messages")
}

enum MessageType {
  TEXT
  FILE
}

enum OrderStatus {
  PENDING
  ACCEPTED
  CANCELLED
  DELIVERED
}

enum ProductCondition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  FAIR
}

enum ProductStatus {
  DRAFT
  ACTIVE
  DELETED
  INACTIVE
  SOLDOUT
}

